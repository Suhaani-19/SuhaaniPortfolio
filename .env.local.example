# MongoDB connection string (get this from MongoDB Atlas — free tier is fine)
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/portfolio
MONGODB_URI=

# Gmail address you'll send contact-form notifications FROM and receive them AT
EMAIL_USER=

# Gmail App Password (NOT your normal Gmail password)
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your Google account)
EMAIL_APP_PASSWORD=

# Optional: a GitHub personal access token (no special scopes needed) to
# avoid GitHub's low unauthenticated rate limit on the /api/github route.
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=
